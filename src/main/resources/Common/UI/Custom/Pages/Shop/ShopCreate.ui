// ShopCreate UI -- Creation wizard for player shops (420x480)
$C = "../../Common.ui";

$C.@PageOverlay {
    Group #CreateLayout {
        LayoutMode: CenterMiddle;

        $C.@DecoratedContainer #CreatePanel {
            Anchor: (Width: 420, Height: 480);

            #Title {
                Group {
                    LayoutMode: Left;
                    Anchor: (Height: 42);

                    Group { FlexWeight: 1; }

                    Label #CreateTitle {
                        Style: (FontSize: 16, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
                        Text: "CREATE YOUR SHOP";
                    }

                    Group { FlexWeight: 1; }
                }
            }

            #Content {
                LayoutMode: Top;
                Padding: (Left: 17, Right: 17, Top: 12, Bottom: 12);

                // ---- Shop Name ----
                Label #NameLabel {
                    Anchor: (Height: 18);
                    Style: (FontSize: 10, TextColor: #96a9be, RenderBold: true, RenderUppercase: true);
                    Text: "SHOP NAME";
                }
                Group { Anchor: (Height: 4); }
                $C.@TextField #ShopNameField {
                    @PlaceholderText = "Enter shop name...";
                    Anchor: (Left: 0, Right: 0, Height: 30);
                    MaxLength: 48;
                }

                Group { Anchor: (Height: 10); }

                // ---- Category ----
                Label #CategoryLabel {
                    Anchor: (Height: 18);
                    Style: (FontSize: 10, TextColor: #96a9be, RenderBold: true, RenderUppercase: true);
                    Text: "CATEGORY";
                }
                Group { Anchor: (Height: 4); }
                $C.@DropdownBox #CategoryDropdown {
                    Anchor: (Left: 0, Right: 0, Height: $C.@DropdownBoxHeight);

                    DropdownEntry { Value: "weapons"; Text: "Weapons"; }
                    DropdownEntry { Value: "armor"; Text: "Armor"; }
                    DropdownEntry { Value: "tools"; Text: "Tools"; }
                    DropdownEntry { Value: "resources"; Text: "Resources"; }
                    DropdownEntry { Value: "potions"; Text: "Potions"; }
                    DropdownEntry { Value: "food"; Text: "Food"; }
                    DropdownEntry { Value: "building"; Text: "Building"; }
                    DropdownEntry { Value: "misc"; Text: "Misc"; }
                }

                Group { Anchor: (Height: 10); }

                // ---- Description ----
                Label #DescLabel {
                    Anchor: (Height: 18);
                    Style: (FontSize: 10, TextColor: #96a9be, RenderBold: true, RenderUppercase: true);
                    Text: "DESCRIPTION (OPTIONAL)";
                }
                Group { Anchor: (Height: 4); }
                $C.@TextField #DescField {
                    @PlaceholderText = "Short description...";
                    Anchor: (Left: 0, Right: 0, Height: 30);
                    MaxLength: 256;
                }

                Group { Anchor: (Height: 10); }

                // ---- Separator ----
                Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff15); }

                Group { Anchor: (Height: 10); }

                // ---- Preview ----
                Group #PreviewSection {
                    Anchor: (Left: 0, Right: 0);
                    LayoutMode: Top;
                    Padding: (Left: 10, Right: 10, Top: 8, Bottom: 8);
                    Background: (Color: #ffffff06);

                    Label #PreviewName {
                        Anchor: (Height: 20);
                        Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, VerticalAlignment: Center);
                        Text: "My Shop";
                    }
                    Label #PreviewCategory {
                        Anchor: (Height: 16);
                        Style: (FontSize: 10, TextColor: #5a6a7a, VerticalAlignment: Center);
                        Text: "Weapons";
                    }
                    Label #PreviewOwner {
                        Anchor: (Height: 16);
                        Style: (FontSize: 10, TextColor: #7caacc, VerticalAlignment: Center);
                        Text: "";
                    }
                }

                Group { Anchor: (Height: 8); }

                // ---- Cost ----
                Group #CostSection {
                    Anchor: (Left: 0, Right: 0, Height: 28);
                    LayoutMode: Left;
                    Padding: (Left: 10);

                    ItemIcon #CostIcon {
                        Anchor: (Width: 18, Height: 18);
                        ItemId: "Ingredient_Bar_Gold";
                    }
                    Group { Anchor: (Width: 6); }
                    Label #CostAmount {
                        Style: (FontSize: 13, TextColor: #ffd700, VerticalAlignment: Center, RenderBold: true);
                        Text: "500";
                    }
                    Group { Anchor: (Width: 10); }
                    Label #TaxInfo {
                        Style: (FontSize: 10, TextColor: #5a6a7a, VerticalAlignment: Center);
                        Text: "";
                    }
                }

                Group { FlexWeight: 1; }

                // ---- Buttons ----
                Group #ButtonSection {
                    Anchor: (Left: 0, Right: 0, Height: 40);
                    LayoutMode: Left;
                    Padding: (Left: 20, Right: 20);

                    Group { FlexWeight: 1; }

                    $C.@TextButton #CreateBtn {
                        @Anchor = (Width: 160, Height: 34);
                        @Text = "CREATE SHOP";
                    }

                    Group { Anchor: (Width: 12); }

                    $C.@CancelTextButton #CancelBtn {
                        @Anchor = (Width: 140, Height: 34);
                        @Text = "CANCEL";
                    }

                    Group { FlexWeight: 1; }
                }
            }
        }
    }
}

