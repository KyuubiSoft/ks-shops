// ShopRating UI -- Rate a shop and view reviews (480x520)
$C = "../../Common.ui";

// ===== Star Button Styles =====
@StarButtonDefault = ButtonStyle(
  Default: (Background: (Color: #333344)),
  Hovered: (Background: (Color: #444455)),
  Pressed: (Background: (Color: #2a2a3a)),
);

@StarButtonSelected = ButtonStyle(
  Default: (Background: (Color: #ffd700)),
  Hovered: (Background: (Color: #ffe44d)),
  Pressed: (Background: (Color: #ccaa00)),
);

// ===== Review Entry Macro =====
@ReviewEntry = Group {
  Visible: false;
  Anchor: (Left: 0, Right: 0, Height: 56);
  LayoutMode: Top;
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
  Background: (Color: #ffffff06);

  Group {
    LayoutMode: Left;
    Anchor: (Left: 0, Right: 0, Height: 16);

    Label #RevStars {
      Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center);
      Text: "";
    }
    Group { Anchor: (Width: 8); }
    Label #RevAuthor {
      Style: (FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center);
      Text: "";
      FlexWeight: 1;
    }
    Label #RevTime {
      Style: (FontSize: 10, TextColor: #5a6a7a, VerticalAlignment: Center, HorizontalAlignment: End);
      Text: "";
    }
  }

  Label #RevComment {
    Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center, WrapText: true);
    Text: "";
    Anchor: (Left: 0, Right: 0);
    FlexWeight: 1;
    Padding: (Top: 2);
  }
};

// ===== Page Layout =====

$C.@PageOverlay {
  Group #RatingLayout {
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #RatingPanel {
      Anchor: (Width: 480, Height: 520);

      #Title {
        Group {
          LayoutMode: Left;
          Anchor: (Height: 42);

          Group { FlexWeight: 1; }

          Label #RatingTitle {
            Style: (FontSize: 16, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, LetterSpacing: 2);
            Text: "RATE SHOP";
          }

          Group { FlexWeight: 1; }
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Left: 17, Right: 17, Top: 12, Bottom: 12);

        // ---- YOUR RATING section header ----
        Label #YourRatingHeader {
          Anchor: (Height: 18);
          Style: (FontSize: 13, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true);
          Text: "YOUR RATING";
        }

        Group { Anchor: (Height: 6); }

        // ---- Star Selector ----
        Group #StarSelector {
          Anchor: (Left: 0, Right: 0, Height: 50);
          LayoutMode: Left;
          Padding: (Left: 100, Right: 100);

          Group { FlexWeight: 1; }

          Button #Star1 {
            Anchor: (Width: 44, Height: 44);
            Style: @StarButtonDefault;
            LayoutMode: CenterMiddle;
            Label #StarLabel1 {
              Style: (FontSize: 22, TextColor: #555566, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "*";
            }
          }

          Group { Anchor: (Width: 4); }

          Button #Star2 {
            Anchor: (Width: 44, Height: 44);
            Style: @StarButtonDefault;
            LayoutMode: CenterMiddle;
            Label #StarLabel2 {
              Style: (FontSize: 22, TextColor: #555566, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "*";
            }
          }

          Group { Anchor: (Width: 4); }

          Button #Star3 {
            Anchor: (Width: 44, Height: 44);
            Style: @StarButtonDefault;
            LayoutMode: CenterMiddle;
            Label #StarLabel3 {
              Style: (FontSize: 22, TextColor: #555566, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "*";
            }
          }

          Group { Anchor: (Width: 4); }

          Button #Star4 {
            Anchor: (Width: 44, Height: 44);
            Style: @StarButtonDefault;
            LayoutMode: CenterMiddle;
            Label #StarLabel4 {
              Style: (FontSize: 22, TextColor: #555566, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "*";
            }
          }

          Group { Anchor: (Width: 4); }

          Button #Star5 {
            Anchor: (Width: 44, Height: 44);
            Style: @StarButtonDefault;
            LayoutMode: CenterMiddle;
            Label #StarLabel5 {
              Style: (FontSize: 22, TextColor: #555566, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "*";
            }
          }

          Group { FlexWeight: 1; }
        }

        // ---- Selected rating feedback ----
        Label #SelectedRating {
          Anchor: (Height: 18);
          Style: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
        }

        Group { Anchor: (Height: 6); }

        // ---- Separator ----
        Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff15); }

        Group { Anchor: (Height: 8); }

        // ---- Comment field ----
        Label #CommentLabel {
          Anchor: (Height: 16);
          Style: (FontSize: 11, TextColor: #96a9be);
          Text: "Comment (optional):";
        }

        Group { Anchor: (Height: 4); }

        $C.@TextField #CommentField {
          @PlaceholderText = "Share your experience...";
          Anchor: (Left: 20, Right: 20, Height: 50);
          MaxLength: 200;
        }

        Group { Anchor: (Height: 8); }

        // ---- Submit button ----
        Group #SubmitSection {
          Anchor: (Left: 0, Right: 0, Height: 36);
          LayoutMode: CenterMiddle;

          $C.@TextButton #SubmitBtn {
            @Anchor = (Width: 200, Height: 32);
            @Text = "SUBMIT RATING";
          }
        }

        Group { Anchor: (Height: 8); }

        // ---- Separator ----
        Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff15); }

        Group { Anchor: (Height: 6); }

        // ---- Reviews header ----
        Group #ReviewsHeaderBar {
          Anchor: (Left: 0, Right: 0, Height: 20);
          LayoutMode: Left;

          Label #ReviewsHeader {
            Style: (FontSize: 13, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center);
            Text: "REVIEWS";
            FlexWeight: 1;
          }

          Label #AvgRating {
            Style: (FontSize: 11, TextColor: #ffd700, VerticalAlignment: Center, HorizontalAlignment: End);
            Text: "";
          }
        }

        Group { Anchor: (Height: 4); }

        // ---- Reviews list ----
        Group #ReviewsList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          @ReviewEntry #Review0 {}
          @ReviewEntry #Review1 {}
          @ReviewEntry #Review2 {}
          @ReviewEntry #Review3 {}
          @ReviewEntry #Review4 {}
        }

        // ---- Review pagination ----
        Group #ReviewPagination {
          Anchor: (Left: 0, Right: 0, Height: 28);
          LayoutMode: Left;
          Padding: (Left: 10, Right: 10);

          $C.@SmallSecondaryTextButton #RevPrevBtn {
            @Anchor = (Width: 44);
            @Text = "<";
            Visible: false;
          }

          Group { FlexWeight: 1; LayoutMode: CenterMiddle;
            Label #RevPageInfo {
              Style: (FontSize: 11, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "1/1";
            }
          }

          $C.@SmallSecondaryTextButton #RevNextBtn {
            @Anchor = (Width: 44);
            @Text = ">";
            Visible: false;
          }
        }
      }
    }
  }
}

$C.@BackButton {}
