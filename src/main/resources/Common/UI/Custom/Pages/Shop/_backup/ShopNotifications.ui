// ShopNotifications UI -- Offline sale notifications (500x520)
$C = "../../Common.ui";

// ===== Sale Row Macro =====
@SaleRow = Group {
  Visible: false;
  Anchor: (Left: 0, Right: 0, Height: 48);
  LayoutMode: Left;
  Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
  Background: (Color: #ffffff06);

  ItemSlot #SaleIcon {
    Anchor: (Width: 36, Height: 36);
    ShowQualityBackground: true;
    ShowQuantity: false;
  }

  Group { Anchor: (Width: 8); }

  Group {
    FlexWeight: 1;
    LayoutMode: Top;

    Group {
      LayoutMode: Left;
      Anchor: (Height: 18);

      Label #SaleBuyer {
        Style: (FontSize: 12, TextColor: #bfcdd5, VerticalAlignment: Center, RenderBold: true);
        Text: "";
        FlexWeight: 1;
      }

      Label #SaleTime {
        Style: (FontSize: 10, TextColor: #5a6a7a, VerticalAlignment: Center, HorizontalAlignment: End);
        Text: "";
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 18);

      Label #SaleDetail {
        Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center);
        Text: "";
        FlexWeight: 1;
      }

      Label #SalePrice {
        Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center, HorizontalAlignment: End, RenderBold: true);
        Text: "";
      }
    }
  }
};

// ===== Page Layout =====

$C.@PageOverlay {
  Group #NotificationsLayout {
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #NotificationsPanel {
      Anchor: (Width: 500, Height: 520);

      #Title {
        Group {
          LayoutMode: Left;
          Anchor: (Height: 42);

          Group { FlexWeight: 1; }

          Label #NotifTitle {
            Style: (FontSize: 16, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true, LetterSpacing: 2);
            Text: "SHOP NOTIFICATIONS";
          }

          Group { FlexWeight: 1; }
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Left: 17, Right: 17, Top: 12, Bottom: 12);

        // ---- Summary section ----
        Group #Summary {
          Anchor: (Left: 0, Right: 0, Height: 70);
          LayoutMode: Top;
          Padding: (Left: 8, Right: 8, Top: 4, Bottom: 4);
          Background: (Color: #ffffff08);

          Label #SummaryHeader {
            Anchor: (Height: 18);
            Style: (FontSize: 13, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true);
            Text: "SINCE LAST LOGIN";
          }

          Label #TotalEarnings {
            Anchor: (Height: 24);
            Style: (FontSize: 16, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center);
            Text: "+0 Gold";
          }

          Label #ItemsSold {
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
            Text: "0 items sold";
          }
        }

        Group { Anchor: (Height: 6); }

        // ---- Separator ----
        Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff15); }

        Group { Anchor: (Height: 6); }

        // ---- Recent Sales header ----
        Label #SalesHeader {
          Anchor: (Height: 18);
          Style: (FontSize: 13, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true);
          Text: "RECENT SALES";
        }

        Group { Anchor: (Height: 4); }

        // ---- Sales list ----
        Group #SalesList {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;

          @SaleRow #Sale0 {}
          @SaleRow #Sale1 {}
          @SaleRow #Sale2 {}
          @SaleRow #Sale3 {}
          @SaleRow #Sale4 {}
          @SaleRow #Sale5 {}
          @SaleRow #Sale6 {}
          @SaleRow #Sale7 {}
        }

        // ---- Pagination ----
        Group #Pagination {
          Anchor: (Left: 0, Right: 0, Height: 28);
          LayoutMode: Left;
          Padding: (Left: 10, Right: 10);

          $C.@SmallSecondaryTextButton #NotifPrev {
            @Anchor = (Width: 44);
            @Text = "<";
            Visible: false;
          }

          Group { FlexWeight: 1; LayoutMode: CenterMiddle;
            Label #NotifPageInfo {
              Style: (FontSize: 11, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "1/1";
            }
          }

          $C.@SmallSecondaryTextButton #NotifNext {
            @Anchor = (Width: 44);
            @Text = ">";
            Visible: false;
          }
        }

        Group { Anchor: (Height: 6); }

        // ---- Actions ----
        Group #Actions {
          Anchor: (Left: 0, Right: 0, Height: 38);
          LayoutMode: Left;
          Padding: (Left: 40, Right: 40);

          $C.@TextButton #MarkReadBtn {
            @Anchor = (Width: 200);
            @Text = "MARK ALL READ";
          }

          Group { FlexWeight: 1; }

          $C.@SecondaryTextButton #CloseBtn {
            @Anchor = (Width: 140);
            @Text = "CLOSE";
          }
        }
      }
    }
  }
}

$C.@BackButton {}
