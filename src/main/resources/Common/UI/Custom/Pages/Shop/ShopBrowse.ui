// ShopBrowse UI - Buyer view for KS-Shops (native ItemGrid, 9x5 = 45 slots)
$C = "../../Common.ui";

// ===== ItemGrid Style for the browse grid =====
@BrowseSlotStyle = ItemGridStyle(
    SlotSpacing: 4,
    SlotSize: 48,
    SlotIconSize: 40,
    SlotBackground: "../../Pages/Bank/BankSlot.png"
);

// ===== Card Macro - kept for backwards compatibility, no longer instantiated =====
@CardButtonStyle = ButtonStyle(
  Default: (Background: (Color: #1c2835)),
  Hovered: (Background: (Color: #2a3a4a)),
  Pressed: (Background: (Color: #1a2a38)),
  Disabled: (Background: (Color: #141a22)),
);

@ShopCard = Group {
  Visible: false;
  Anchor: (Width: 218, Height: 178);
  Padding: (Full: 4);

  Button #CardBtn {
    Anchor: (Full: 0);
    LayoutMode: Full;
    Padding: (Full: 2);
    Style: @CardButtonStyle;
    TooltipText: "";

    Group #CardContent {
      Anchor: (Full: 0);
      LayoutMode: Top;

      // Item icon
      Group #IconSection {
        Anchor: (Height: 80);
        Padding: (Top: 6);
        LayoutMode: CenterMiddle;

        Group {
          Anchor: (Width: 68, Height: 68);

          Group #SlotBorder {
            Anchor: (Full: 0);
            Background: (Color: #1a2530);
            Padding: (Full: 2);

            ItemIcon #ItemIcon {
              Anchor: (Full: 0);
            }
          }

          Label #Quantity {
            Anchor: (Right: 6, Bottom: 4);
            Style: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: End, VerticalAlignment: End, RenderBold: true);
            Text: "";
          }
        }
      }

      // Name
      Group #NameSection {
        Anchor: (Height: 22);
        LayoutMode: CenterMiddle;

        Label #Name {
          Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Padding: (Horizontal: 6);
        }
      }

      // Divider
      Group {
        Anchor: (Height: 6);
        LayoutMode: CenterMiddle;
        Group { Anchor: (Width: 140, Height: 1); Background: (Color: #252f3a); }
      }

      // Cost
      Group #CostSection {
        Anchor: (Height: 42);
        LayoutMode: Top;
        Padding: (Top: 2);

        Group {
          LayoutMode: CenterMiddle;
          Anchor: (Height: 22);

          Group {
            LayoutMode: Left;

            ItemIcon #CostIcon {
              Anchor: (Width: 18, Height: 18);
            }
            Group { Anchor: (Width: 4); }
            Label #Cost {
              Style: (FontSize: 13, TextColor: #7caacc, VerticalAlignment: Center, RenderBold: true);
              Text: "";
            }
          }
        }

        Label #LimitInfo {
          Style: (FontSize: 10, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Anchor: (Height: 16);
        }
      }
    }

    // Sold out / can't afford / out of stock overlay
    Group #Overlay {
      Anchor: (Full: 0);
      Background: (Color: #0a0e12(0.75));
      LayoutMode: CenterMiddle;
      Visible: false;

      Label #OverlayText {
        Style: (FontSize: 14, TextColor: #cc4444, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true);
        Text: "";
      }
    }
  }
};

// ===== Page Layout =====

$C.@PageOverlay {
  Group #HubLayout {
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #MainContent {
      Anchor: (Width: 740, Height: 580);

      #Title {
        Group {
          LayoutMode: Left;
          Anchor: (Height: 42);

          // Shop avatar (owner-picked icon, falls back to first shop item)
          Group {
            Anchor: (Width: 120, Height: 42);
            LayoutMode: Left;
            Padding: (Left: 15, Top: 6);

            Group {
              Anchor: (Width: 30, Height: 30);
              Background: (Color: #1a2530);
              Padding: (Full: 2);
              ItemIcon #ShopAvatar {
                Anchor: (Full: 0);
              }
            }
          }

          Label #ShopTitle {
            Style: (FontSize: 18, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
            Text: "";
            FlexWeight: 1;
            Padding: (Top: 6);
          }

          Group #CurrencyDisplay {
            Anchor: (Width: 120, Height: 32);
            LayoutMode: Left;
            Padding: (Top: 5, Right: 15);

            ItemIcon #CurrencyIcon {
              Anchor: (Width: 22, Height: 22);
              ItemId: "Ingredient_Bar_Gold";
            }
            Group { Anchor: (Width: 6); }
            Label #CurrencyBalance {
              Style: (FontSize: 14, RenderBold: true, TextColor: #ffd700, VerticalAlignment: Center);
              Text: "0";
              FlexWeight: 1;
            }
          }
        }
      }

      #Content {
        LayoutMode: Top;

        // Info Bar: back, owner, rating, item count, rate button
        Group #InfoBar {
          Anchor: (Height: 28);
          LayoutMode: Left;
          Padding: (Left: 15, Right: 15, Top: 2);

          $C.@SmallSecondaryTextButton #BackBtn {
            @Anchor = (Width: 90);
            @Text = "< BACK";
          }

          Group { Anchor: (Width: 12); }

          Label #InfoOwner {
            Style: (FontSize: 11, TextColor: #96a9be, VerticalAlignment: Center);
            Text: "";
            FlexWeight: 1;
          }

          Group { Anchor: (Width: 8); }

          Label #InfoRating {
            Style: (FontSize: 11, TextColor: #ffd700, VerticalAlignment: Center);
            Text: "";
          }

          Group { Anchor: (Width: 8); }

          Label #InfoItemCount {
            Style: (FontSize: 11, TextColor: #5a6a7a, VerticalAlignment: Center);
            Text: "";
          }

          Group { Anchor: (Width: 10); }

          $C.@SmallSecondaryTextButton #RateButton {
            @Anchor = (Width: 60);
            @Text = "Rate";
            Visible: false;
          }
        }

        // Tab Bar (Buy / Sell)
        Group #TabBar {
          Visible: false;
          Anchor: (Height: 36);
          LayoutMode: Left;
          Padding: (Left: 15, Right: 15, Top: 4, Bottom: 4);

          TextButton #BuyTab {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: $C.@DefaultTextButtonStyle;
            Text: "BUY";
          }

          Group { Anchor: (Width: 6); }

          TextButton #SellTab {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: $C.@SecondaryTextButtonStyle;
            Text: "SELL";
          }
        }

        // Custom 5x3 card grid (15 items per page, click to buy).
        // Each card shows icon, item name, price, and stock visibly - no
        // hover needed. Replaces the previous native ItemGrid, which had no
        // per-slot label widgets for the price.
        Group #CardContainer {
          FlexWeight: 1;
          LayoutMode: CenterMiddle;
          Padding: (Left: 10, Right: 10, Top: 6);

          Group #BrowseGrid {
            Anchor: (Width: 680, Height: 370);
            LayoutMode: LeftCenterWrap;

            Group #BrowseCard0 { Visible: false; Anchor: (Width: 130, Height: 120); Padding: (Full: 4);
              Button #BrowseBtn0 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 3); Style: @BrowseCardStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 58); LayoutMode: CenterMiddle;
                    Group { Anchor: (Width: 54, Height: 54); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
                      ItemIcon #BrowseIcon0 { Anchor: (Width: 50, Height: 50); ItemId: "Ingredient_Bar_Gold"; } } }
                  Label #BrowseName0 { Anchor: (Left: 0, Right: 0, Height: 14); Style: (FontSize: 11, TextColor: #bfcdd5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowsePrice0 { Anchor: (Left: 0, Right: 0, Height: 16); Style: (FontSize: 13, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowseStock0 { Anchor: (Left: 0, Right: 0, Height: 12); Style: (FontSize: 9, TextColor: #66bb6a, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; } } } }

            Group #BrowseCard1 { Visible: false; Anchor: (Width: 130, Height: 120); Padding: (Full: 4);
              Button #BrowseBtn1 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 3); Style: @BrowseCardStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 58); LayoutMode: CenterMiddle;
                    Group { Anchor: (Width: 54, Height: 54); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
                      ItemIcon #BrowseIcon1 { Anchor: (Width: 50, Height: 50); ItemId: "Ingredient_Bar_Gold"; } } }
                  Label #BrowseName1 { Anchor: (Left: 0, Right: 0, Height: 14); Style: (FontSize: 11, TextColor: #bfcdd5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowsePrice1 { Anchor: (Left: 0, Right: 0, Height: 16); Style: (FontSize: 13, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowseStock1 { Anchor: (Left: 0, Right: 0, Height: 12); Style: (FontSize: 9, TextColor: #66bb6a, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; } } } }

