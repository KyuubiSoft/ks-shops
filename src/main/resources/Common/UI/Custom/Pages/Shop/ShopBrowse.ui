                      ItemIcon #BrowseIcon14 { Anchor: (Width: 50, Height: 50); ItemId: "Ingredient_Bar_Gold"; } } }
                  Label #BrowseName14 { Anchor: (Left: 0, Right: 0, Height: 14); Style: (FontSize: 11, TextColor: #bfcdd5, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowsePrice14 { Anchor: (Left: 0, Right: 0, Height: 16); Style: (FontSize: 13, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; }
                  Label #BrowseStock14 { Anchor: (Left: 0, Right: 0, Height: 12); Style: (FontSize: 9, TextColor: #66bb6a, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; } } } }
          }
        }

        // Empty State - shown when the active list has no items
        Group #EmptyStateLabel {
          Visible: false;
          FlexWeight: 1;
          LayoutMode: CenterMiddle;

          Label {
            Style: (FontSize: 14, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "This shop has no items available.";
          }
        }

        // Footer - Pagination
        Group #Footer {
          Anchor: (Height: 42);
          LayoutMode: Top;
          Padding: (Horizontal: 10);

          Group { Anchor: (Height: 2); Background: (Color: #19252f); }

          Group {
            FlexWeight: 1;
            LayoutMode: Left;
            Padding: (Left: 10, Right: 10);

            $C.@SmallSecondaryTextButton #PrevButton {
              @Anchor = (Width: 70);
              @Text = "<";
              Visible: false;
            }

            Group { FlexWeight: 1; }

            Label #PageInfo {
              Anchor: (Width: 100);
              Style: (FontSize: 12, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "Page 1/1";
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #NextButton {
              @Anchor = (Width: 70);
              @Text = ">";
              Visible: false;
            }
          }
        }
      }
    }
  }

  // Confirmation Overlay (Buy/Sell)
  Group #ConfirmOverlay {
    Visible: false;
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: CenterMiddle;
    Background: (Color: #00000088);

    $C.@Container #ConfirmDialog {
      Anchor: (Width: 340, Height: 280);

      #Title {
        Label #ConfirmTitle {
          Style: (FontSize: 18, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
          Padding: (Horizontal: 19);
          Text: "";
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 12);

        Group {
          LayoutMode: Left;
          Anchor: (Height: 52);

          Group { FlexWeight: 1; }

          Group #ConfirmIconBg {
            Anchor: (Width: 48, Height: 48);
            Background: (Color: #1a2530);
            Padding: (Full: 2);
            ItemSlot #ConfirmIcon { Anchor: (Full: 0); ShowQualityBackground: true; ShowQuantity: false; }
          }

          Group { Anchor: (Width: 10); }

          Group {
            FlexWeight: 2;
            LayoutMode: Top;
            Label #ConfirmItemName {
              Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true);
              Text: "";
              Anchor: (Height: 22);
            }
            Label #ConfirmPrice {
              Style: (FontSize: 12, TextColor: #7caacc, RenderBold: true);
              Text: "";
              Anchor: (Height: 18);
            }
          }

          Group { FlexWeight: 1; }
        }

        // Tax display
        Label #ConfirmTax {
          Style: (FontSize: 10, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Anchor: (Height: 16);
          Visible: false;
        }

        Group { Anchor: (Height: 6); }

        // Quantity slider (SliderNumberField centered in the row with equal
        // side-label widths so the slider track sits symmetrically in the
        // middle of the dialog).
        Group {
          LayoutMode: Left;
          Anchor: (Height: 34);
          Padding: (Left: 20, Right: 20, Top: 8);

          Label {
            Anchor: (Width: 50, Height: 18);
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
            Text: "Qty";
          }

          Group {
            FlexWeight: 1;
            LayoutMode: CenterMiddle;

            SliderNumberField #ConfirmQtySlider {
              Anchor: (Width: 200, Height: 5);
              SliderStyle: $C.@DefaultSliderStyle;
              NumberFieldStyle: $C.@DefaultInputFieldStyle;
              Min: 1;
              Max: 64;
            }
          }

          Label #ConfirmQty {
            Anchor: (Width: 50, Height: 18);
            Style: (FontSize: 16, RenderBold: true, TextColor: #ffffff, HorizontalAlignment: End, VerticalAlignment: Center);
            Text: "1";
          }
        }

        Label #ConfirmTotal {
          Style: (FontSize: 12, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Anchor: (Height: 20);
        }

        Group { FlexWeight: 1; }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38);
          Padding: (Left: 6, Right: 6);

          $C.@TextButton #ConfirmYes {
            @Anchor = (Width: 140);
            @Text = "CONFIRM";
          }

          Group { FlexWeight: 1; }

          $C.@CancelTextButton #ConfirmNo {
            @Anchor = (Width: 140);
            @Text = "CANCEL";
          }
        }
      }
    }
  }
}

