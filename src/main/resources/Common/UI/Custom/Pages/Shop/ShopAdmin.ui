                  Label #RentState7 { Anchor: (Width: 70); Style: LabelStyle(FontSize: 10, TextColor: #66bb6a, RenderBold: true, VerticalAlignment: Center); Text: ""; }
                  Label #RentPrice7 { Anchor: (Width: 80); Style: LabelStyle(FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; }
                  Label #RentRenter7 { FlexWeight: 1; Style: LabelStyle(FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Button #RentExpireBtn7 { Anchor: (Width: 40, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ffaa0020)), Hovered: (Background: (Color: #ffaa0040)), Pressed: (Background: (Color: #ffaa0060))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ffaa00, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "EXP"; } }
                  Group { Anchor: (Width: 3); }
                  Button #RentDeleteBtn7 { Anchor: (Width: 40, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
                }

                Label #RentEmpty { Anchor: (Height: 30); Style: LabelStyle(FontSize: 11, TextColor: #556677, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "No rental slots found. Use /kssa createrental or /kssa createrentalauction to create one."; }

                // --- Pagination ---
                Group { Anchor: (Height: 4); }
                Group { Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left;
                  Button #RentPrevBtn { Anchor: (Width: 30, Height: 24); Style: $C.@SecondaryButtonStyle; LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 12, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "<"; } }
                  Group { FlexWeight: 1; }
                  Label #RentPageInfo { Style: LabelStyle(FontSize: 10, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "1/1"; }
                  Group { FlexWeight: 1; }
                  Button #RentNextBtn { Anchor: (Width: 30, Height: 24); Style: $C.@SecondaryButtonStyle; LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 12, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ">"; } }
                }
              }

              // ========== STATISTICS PANEL ==========
              Group #SAPanelStats { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "Statistics"; }
                Group { Anchor: (Height: 8); }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Total Shops:"; }
                  Label #StatTotalShops { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Player Shops:"; }
                  Label #StatPlayerShops { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Admin Shops:"; }
                  Label #StatAdminShops { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Active Shops:"; }
                  Label #StatActiveShops { Style: LabelStyle(FontSize: 12, TextColor: #44ff44, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Closed Shops:"; }
                  Label #StatClosedShops { Style: LabelStyle(FontSize: 12, TextColor: #ff4444, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 1, Top: 4, Bottom: 4); Background: (Color: #ffffff10); }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Total Volume:"; }
                  Label #StatTotalVolume { Style: LabelStyle(FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Tax Collected:"; }
                  Label #StatTaxCollected { Style: LabelStyle(FontSize: 12, TextColor: #ff8800, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Rent Collected:"; }
                  Label #StatRentCollected { Style: LabelStyle(FontSize: 12, TextColor: #00bcd4, VerticalAlignment: Center); Text: "0"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 1, Top: 4, Bottom: 4); Background: (Color: #ffffff10); }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Top Seller:"; }
                  Label #StatTopSeller { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "-"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Top Item:"; }
                  Label #StatTopItem { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "-"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  Label { Anchor: (Width: 180); Style: LabelStyle(FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center); Text: "Transactions Today:"; }
                  Label #StatTransactionsToday { Style: LabelStyle(FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: "-"; }
                }
              }

              // ========== BLACKLIST PANEL ==========
              Group #SAPanelBlacklist { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "Item Blacklist"; }
                Group { Anchor: (Height: 6); }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  $C.@TextField #BItemField { Anchor: (Height: 28); FlexWeight: 1; MaxLength: 80; }
                  Group { Anchor: (Width: 6); }
                  Button #BAddBtn {
                    Anchor: (Width: 50, Height: 28);
                    Style: ButtonStyle(Default: (Background: (Color: #44ff4420)), Hovered: (Background: (Color: #44ff4440)), Pressed: (Background: (Color: #44ff4460)));
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Add"; }
                  }
                }
                Group { Anchor: (Height: 6); }
                // Rows 0-9
                Group #BRow0 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId0 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn0 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow1 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
