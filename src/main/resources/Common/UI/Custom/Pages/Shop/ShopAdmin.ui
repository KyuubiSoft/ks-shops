// ShopAdmin UI -- Admin panel with sidebar tabs (960x700)
$C = "../../Common.ui";

$C.@PageOverlay {
  Group {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: CenterMiddle;

  $C.@DecoratedContainer #SAPanel {
    @ContentPadding = Padding(Left: 0, Right: 0, Top: 0, Bottom: 0);
    Anchor: (Width: 960, Height: 700);

    #Title {
      Group {
        Anchor: (Height: 48);
        LayoutMode: Left;
        Padding: (Left: 16, Right: 8);

        Group { Anchor: (Width: 8); }

        Label #SATitleLbl {
          FlexWeight: 1;
          Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "SHOP ADMINISTRATION";
        }

        Button #SAReloadBtn {
          Anchor: (Width: 80, Height: 32);
          LayoutMode: CenterMiddle;
          Style: ButtonStyle(
            Default: (Background: (Color: #ff994425)),
            Hovered: (Background: (Color: #ff994445)),
            Pressed: (Background: (Color: #ff994465))
          );
          Label #SAReloadLbl { Style: (FontSize: 11, RenderBold: true, TextColor: #ff9944, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "RELOAD"; }
        }

        Group { Anchor: (Width: 6); }

        Button #SACloseBtn {
          Anchor: (Width: 36, Height: 36);
          LayoutMode: CenterMiddle;
          Style: ButtonStyle(
            Default: (Background: (Color: #ffffff08)),
            Hovered: (Background: (Color: #ff444444)),
            Pressed: (Background: (Color: #ff666666))
          );
          Label #SACloseLbl { Style: (FontSize: 14, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true); Text: "X"; }
        }
      }
    }

    #Content {
      Group {
        Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
        LayoutMode: Full;

        // ===================== LEFT SIDEBAR =====================
        Group #SANav {
          Anchor: (Left: 0, Top: 0, Bottom: 0, Width: 160);
          LayoutMode: Top;
          Padding: (Left: 6, Right: 6, Top: 8, Bottom: 8);
          Background: (Color: #ffffff04);

          // -- SETTINGS --
          Label #SACatSettingsLbl { Style: (FontSize: 10, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true); Text: "SETTINGS"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

          Button #SATabGeneral {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabGeneralInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabGeneralLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "General"; }
          }

          Button #SATabEconomy {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabEconomyInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabEconomyLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Economy"; }
          }

          Button #SATabRent {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabRentInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabRentLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Rent"; }
          }

          Group { Anchor: (Height: 8); }

          // -- MANAGEMENT --
          Label #SACatMgmtLbl { Style: (FontSize: 10, TextColor: #44ff44, RenderBold: true, RenderUppercase: true); Text: "MANAGEMENT"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

          Button #SATabShops {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabShopsInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabShopsLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "All Shops"; }
          }

          Button #SATabPlayers {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabPlayersInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabPlayersLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Player Shops"; }
          }

          Button #SATabTransactions {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabTransactionsInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabTransactionsLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Transactions"; }
          }

          Group { Anchor: (Height: 8); }

          // -- TOOLS --
          Label #SACatToolsLbl { Style: (FontSize: 10, TextColor: #00bfff, RenderBold: true, RenderUppercase: true); Text: "TOOLS"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

          Button #SATabStats {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabStatsInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabStatsLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Statistics"; }
          }

          Button #SATabBlacklist {
            Anchor: (Height: 32, Left: 0, Right: 0);
            Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18)));
            LayoutMode: Left;
            Group #SATabBlacklistInd { Anchor: (Width: 3, Top: 5, Bottom: 5); Background: (Color: #00000000); }
            Group { Anchor: (Width: 8); }
            Label #SATabBlacklistLbl { Style: (FontSize: 12, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Blacklist"; }
          }
        }

        // Vertical separator
        Group { Anchor: (Left: 160, Top: 6, Bottom: 6, Width: 1); Background: (Color: #ffffff15); }

        // ===================== CONTENT AREA =====================
        Group #SAContentArea {
          Anchor: (Left: 161, Top: 0, Right: 0, Bottom: 0);
          LayoutMode: Full;

          // Status message
          Label #SAStatusMsg {
            Anchor: (Left: 0, Right: 0, Top: 0, Height: 24);
            Style: (FontSize: 11, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "";
          }

          // ==================== PANEL: GENERAL ====================
          Group #SAPanelGeneral {
            Visible: true;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true); Text: "GENERAL SETTINGS"; Anchor: (Height: 24); }

            // Max Shops Per Player
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Max Shops Per Player"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GMaxShops { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Max Items Per Shop
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Max Items Per Shop"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GMaxItems { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Creation Cost
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Creation Cost"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GCreationCost { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Shop Name Max Length
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Shop Name Max Length"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GNameMaxLen { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Allow Player Shops
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Allow Player Shops"; }
              Group { FlexWeight: 1; }
              $C.@CheckBox #GAllowPlayerShops { Anchor: (Width: 24, Height: 24, Right: 20); }
            }

            // Auto-Close Inactive Days
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Close Inactive Days"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GAutoCloseDays { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Auto-Delete Inactive Days
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Delete Inactive Days"; }
              Group { FlexWeight: 1; }
              $C.@TextField #GAutoDeleteDays { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Save
            Group { Anchor: (Height: 16); }
            Button #GSaveBtn {
              Anchor: (Width: 140, Height: 36);
              LayoutMode: CenterMiddle;
              Style: ButtonStyle(
                Default: (Background: (Color: #44ff4425)),
                Hovered: (Background: (Color: #44ff4445)),
                Pressed: (Background: (Color: #44ff4465))
              );
              Label #GSaveBtnLbl { Style: (FontSize: 12, RenderBold: true, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "SAVE"; }
            }
          }

          // ==================== PANEL: ECONOMY ====================
          Group #SAPanelEconomy {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true); Text: "TAX SETTINGS"; Anchor: (Height: 24); }

            // Tax Enabled
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Tax Enabled"; }
              Group { FlexWeight: 1; }
              $C.@CheckBox #ETaxEnabled { Anchor: (Width: 24, Height: 24, Right: 20); }
            }

            // Buy Tax Rate
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Buy Tax Rate"; }
              Group { FlexWeight: 1; }
              $C.@TextField #ETaxRate { Anchor: (Width: 160, Right: 10, Height: 28); }
              Label { Anchor: (Width: 30, Right: 0); Style: (VerticalAlignment: Center, TextColor: #778899, FontSize: 13); Text: "%"; }
            }

            // Sell Tax Rate
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Sell Tax Rate"; }
              Group { FlexWeight: 1; }
              $C.@TextField #ESellTaxRate { Anchor: (Width: 160, Right: 10, Height: 28); }
              Label { Anchor: (Width: 30, Right: 0); Style: (VerticalAlignment: Center, TextColor: #778899, FontSize: 13); Text: "%"; }
            }

            // Show Tax in Price
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Display Tax in Price"; }
              Group { FlexWeight: 1; }
              $C.@CheckBox #EDisplayTax { Anchor: (Width: 24, Height: 24, Right: 20); }
            }

            // Save
            Group { Anchor: (Height: 16); }
            Button #ESaveBtn {
              Anchor: (Width: 140, Height: 36);
              LayoutMode: CenterMiddle;
              Style: ButtonStyle(
                Default: (Background: (Color: #44ff4425)),
                Hovered: (Background: (Color: #44ff4445)),
                Pressed: (Background: (Color: #44ff4465))
              );
              Label #ESaveBtnLbl { Style: (FontSize: 12, RenderBold: true, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "SAVE"; }
            }
          }

          // ==================== PANEL: RENT ====================
          Group #SAPanelRent {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #E8A93B, RenderBold: true, RenderUppercase: true); Text: "RENT SETTINGS"; Anchor: (Height: 24); }

            // Rent Enabled
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Rent Enabled"; }
              Group { FlexWeight: 1; }
              $C.@CheckBox #RRentEnabled { Anchor: (Width: 24, Height: 24, Right: 20); }
            }

            // Daily Amount
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Cost Per Day"; }
              Group { FlexWeight: 1; }
              $C.@TextField #RDailyAmount { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Grace Period Days
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Grace Period (days)"; }
              Group { FlexWeight: 1; }
              $C.@TextField #RGraceDays { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Auto-Close On Unpaid
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Close on Unpaid"; }
              Group { FlexWeight: 1; }
              $C.@CheckBox #RAutoClose { Anchor: (Width: 24, Height: 24, Right: 20); }
            }

            // Auto-Delete Days
            Group {
              Anchor: (Left: 0, Right: 0, Height: 44, Bottom: 6);
              LayoutMode: Left;
              Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
              Label { Anchor: (Left: 12); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Delete Unpaid (days)"; }
              Group { FlexWeight: 1; }
              $C.@TextField #RAutoDeleteDays { Anchor: (Width: 200, Right: 10, Height: 28); }
            }

            // Save
            Group { Anchor: (Height: 16); }
            Button #RSaveBtn {
              Anchor: (Width: 140, Height: 36);
              LayoutMode: CenterMiddle;
              Style: ButtonStyle(
                Default: (Background: (Color: #44ff4425)),
                Hovered: (Background: (Color: #44ff4445)),
                Pressed: (Background: (Color: #44ff4465))
              );
              Label #RSaveBtnLbl { Style: (FontSize: 12, RenderBold: true, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "SAVE"; }
            }
          }

          // ==================== PANEL: ALL SHOPS ====================
          Group #SAPanelShops {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #44ff44, RenderBold: true, RenderUppercase: true); Text: "ALL SHOPS"; Anchor: (Height: 24); }

            // Search bar
            Group {
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 10);
              LayoutMode: Left;
              $C.@TextField #SSearchField { FlexWeight: 1; Anchor: (Height: 28); PlaceholderText: "Search shops..."; }
              Group { Anchor: (Width: 8); }
              Button #SSearchBtn {
                Anchor: (Width: 80, Height: 28);
                LayoutMode: CenterMiddle;
                Style: ButtonStyle(Default: (Background: (Color: #00bfff25)), Hovered: (Background: (Color: #00bfff45)), Pressed: (Background: (Color: #00bfff65)));
                Label #SSearchBtnLbl { Style: (FontSize: 11, RenderBold: true, TextColor: #00bfff, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "SEARCH"; }
              }
            }

            // Column headers
            Group {
              Anchor: (Left: 0, Right: 0, Height: 24, Bottom: 4);
              LayoutMode: Left;
              Label { Anchor: (Width: 160); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "NAME"; Padding: (Left: 6); }
              Label { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "OWNER"; }
              Label { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "TYPE"; }
              Label { Anchor: (Width: 50); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "ITEMS"; }
              Label { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "STATUS"; }
              Group { FlexWeight: 1; }
              Label { Anchor: (Width: 100); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: Center); Text: "ACTIONS"; }
            }

            // Row 0
            Group #SRow0 {
              Visible: false;
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 2);
              LayoutMode: Left;
              Background: (Color: #ffffff06);
              Label #SName0 { Anchor: (Width: 160); Style: (FontSize: 12, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; Padding: (Left: 6); }
              Label #SOwner0 { Anchor: (Width: 120); Style: (FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
              Label #SType0 { Anchor: (Width: 60); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Label #SItems0 { Anchor: (Width: 50); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Label #SStatus0 { Anchor: (Width: 60); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Group { FlexWeight: 1; }
              Button #SEditBtn0 {
                Anchor: (Width: 44, Height: 24);
                LayoutMode: CenterMiddle;
                Style: ButtonStyle(Default: (Background: (Color: #00bfff20)), Hovered: (Background: (Color: #00bfff40)), Pressed: (Background: (Color: #00bfff60)));
                Label { Style: (FontSize: 10, RenderBold: true, TextColor: #00bfff, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "EDIT"; }
              }
              Group { Anchor: (Width: 4); }
              Button #SDeleteBtn0 {
                Anchor: (Width: 36, Height: 24);
                LayoutMode: CenterMiddle;
                Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460)));
                Label { Style: (FontSize: 10, RenderBold: true, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; }
              }
            }

            // Row 1
            Group #SRow1 {
              Visible: false;
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 2);
              LayoutMode: Left;
              Background: (Color: #ffffff06);
              Label #SName1 { Anchor: (Width: 160); Style: (FontSize: 12, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; Padding: (Left: 6); }
              Label #SOwner1 { Anchor: (Width: 120); Style: (FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
              Label #SType1 { Anchor: (Width: 60); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Label #SItems1 { Anchor: (Width: 50); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Label #SStatus1 { Anchor: (Width: 60); Style: (FontSize: 11, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
              Group { FlexWeight: 1; }
              Button #SEditBtn1 { Anchor: (Width: 44, Height: 24); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #00bfff20)), Hovered: (Background: (Color: #00bfff40)), Pressed: (Background: (Color: #00bfff60))); Label { Style: (FontSize: 10, RenderBold: true, TextColor: #00bfff, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "EDIT"; } }
              Group { Anchor: (Width: 4); }
              Button #SDeleteBtn1 { Anchor: (Width: 36, Height: 24); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); Label { Style: (FontSize: 10, RenderBold: true, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
            }

            // Row 2
            Group #SRow2 {
              Visible: false;
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 2);
              LayoutMode: Left;
              Background: (Color: #ffffff06);
