// Shop Administration Panel
$C = "../../Common.ui";

$C.@PageOverlay {
  Group {
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #SAPanel {
      @ContentPadding = Padding(Left: 0, Right: 0, Top: 0, Bottom: 0);
      Anchor: (Width: 960, Height: 700);

      #Title {
        Group {
          LayoutMode: Left;
          Anchor: (Height: 48);
          Padding: (Left: 16, Right: 16);
          Group { Anchor: (Width: 8); }
          Label #SATitleLbl {
            FlexWeight: 1;
            Style: LabelStyle(FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "SHOP ADMINISTRATION";
          }
          Group { Anchor: (Width: 8); }
          Button #SAReloadBtn {
            Anchor: (Width: 80, Height: 32);
            Style: ButtonStyle(Default: (Background: (Color: #ffaa0020)), Hovered: (Background: (Color: #ffaa0040)), Pressed: (Background: (Color: #ffaa0060)));
            Label { Style: LabelStyle(FontSize: 10, TextColor: #ffaa00, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Reload"; }
          }
          Group { Anchor: (Width: 8); }
          Button #SACloseBtn {
            Anchor: (Width: 36, Height: 36);
            LayoutMode: CenterMiddle;
            Style: ButtonStyle(Default: (Background: (Color: #ffffff08)), Hovered: (Background: (Color: #ff444444)), Pressed: (Background: (Color: #ff666666)));
            Label { Style: LabelStyle(FontSize: 14, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center, RenderBold: true); Text: "X"; }
          }
        }
      }

      #Content {
        Group {
          Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
          LayoutMode: Left;

          // ==================== SIDEBAR ====================
          Group #SANav {
            Anchor: (Width: 160, Top: 0, Bottom: 0);
            LayoutMode: Top;
            Padding: (Left: 6, Right: 6, Top: 8, Bottom: 8);
            Background: (Color: #ffffff04);

            Label { Style: LabelStyle(FontSize: 10, TextColor: #00bfff, RenderBold: true, RenderUppercase: true); Text: "SETTINGS"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

            Button #SATabGeneral { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabGeneralInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00bfff); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "General"; }
            }
            Button #SATabEconomy { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabEconomyInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Economy"; }
            }
            Button #SATabRent { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabRentInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Rent"; }
            }

            Group { Anchor: (Height: 8); }
            Label { Style: LabelStyle(FontSize: 10, TextColor: #44ff44, RenderBold: true, RenderUppercase: true); Text: "MANAGEMENT"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

            Button #SATabShops { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabShopsInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "All Shops"; }
            }
            Button #SATabPlayers { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabPlayersInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Player Shops"; }
            }
            Button #SATabRentals { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabRentalsInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Rentals"; }
            }
            Button #SATabTransactions { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabTransactionsInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Transactions"; }
            }

            Group { Anchor: (Height: 8); }
            Label { Style: LabelStyle(FontSize: 10, TextColor: #ff8800, RenderBold: true, RenderUppercase: true); Text: "TOOLS"; Anchor: (Height: 22); Padding: (Left: 8, Top: 4); }

            Button #SATabStats { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabStatsInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Statistics"; }
            }
            Button #SATabBlacklist { Anchor: (Height: 34, Left: 0, Right: 0); Style: ButtonStyle(Default: (Background: (Color: #00000000)), Hovered: (Background: (Color: #ffffff10)), Pressed: (Background: (Color: #ffffff18))); LayoutMode: Left;
              Group #SATabBlacklistInd { Anchor: (Width: 3, Top: 6, Bottom: 6); Background: (Color: #00000000); }
              Group { Anchor: (Width: 9); }
              Label { Style: LabelStyle(FontSize: 13, TextColor: #8899aa, VerticalAlignment: Center); FlexWeight: 1; Text: "Blacklist"; }
            }
          }

          // ==================== CONTENT AREA ====================
          Group #SAContentArea {
            FlexWeight: 1;
            LayoutMode: Full;
            Padding: (Left: 20, Top: 16, Right: 20, Bottom: 16);

            Group {
              Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
              LayoutMode: Top;

              Label #SAStatusMsg {
                Anchor: (Left: 0, Right: 0, Height: 20);
                Style: LabelStyle(FontSize: 10, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
                Text: "";
              }
              Group { Anchor: (Height: 8); }

              // ========== GENERAL PANEL ==========
              Group #SAPanelGeneral { Anchor: (Left: 0, Right: 0); LayoutMode: Top;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "General Settings"; }
                Group { Anchor: (Height: 8); }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Max Shops per Player"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GMaxShops { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 4; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Max Items per Shop"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GMaxItems { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 4; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Creation Cost"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GCreationCost { Anchor: (Width: 80, Height: 28, Right: 8); MaxLength: 8; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Name Max Length"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GNameMaxLen { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 3; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Allow Player Shops"; }
                  Group { FlexWeight: 1; }
                  $C.@CheckBox #GAllowPlayerShops { Anchor: (Width: 18, Height: 18, Right: 12); }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Close Days"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GAutoCloseDays { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 4; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Delete Days"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #GAutoDeleteDays { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 4; }
                }
                Group { Anchor: (Height: 12); }
                Button #GSaveBtn {
                  Anchor: (Width: 160, Height: 34);
                  Style: ButtonStyle(Default: (Background: (Color: #44ff4420)), Hovered: (Background: (Color: #44ff4440)), Pressed: (Background: (Color: #44ff4460)));
                  Label { Style: LabelStyle(FontSize: 12, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Save Changes"; }
                }
              }

              // ========== ECONOMY PANEL ==========
              Group #SAPanelEconomy { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "Economy Settings"; }
                Group { Anchor: (Height: 8); }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Tax Enabled"; }
                  Group { FlexWeight: 1; }
                  $C.@CheckBox #ETaxEnabled { Anchor: (Width: 18, Height: 18, Right: 12); }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Buy Tax Rate (%)"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #ETaxRate { Anchor: (Width: 80, Height: 28, Right: 8); MaxLength: 6; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Sell Tax Rate (%)"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #ESellTaxRate { Anchor: (Width: 80, Height: 28, Right: 8); MaxLength: 6; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Display Tax in Price"; }
                  Group { FlexWeight: 1; }
                  $C.@CheckBox #EDisplayTax { Anchor: (Width: 18, Height: 18, Right: 12); }
                }
                Group { Anchor: (Height: 12); }
                Button #ESaveBtn {
                  Anchor: (Width: 160, Height: 34);
                  Style: ButtonStyle(Default: (Background: (Color: #44ff4420)), Hovered: (Background: (Color: #44ff4440)), Pressed: (Background: (Color: #44ff4460)));
                  Label { Style: LabelStyle(FontSize: 12, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Save Economy"; }
                }
              }

              // ========== RENT PANEL ==========
              Group #SAPanelRent { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "Rent Settings"; }
                Group { Anchor: (Height: 8); }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Rent Enabled"; }
                  Group { FlexWeight: 1; }
                  $C.@CheckBox #RRentEnabled { Anchor: (Width: 18, Height: 18, Right: 12); }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Daily Amount"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #RDailyAmount { Anchor: (Width: 80, Height: 28, Right: 8); MaxLength: 8; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Grace Period (Days)"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #RGraceDays { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 3; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Close on Expire"; }
                  Group { FlexWeight: 1; }
                  $C.@CheckBox #RAutoClose { Anchor: (Width: 18, Height: 18, Right: 12); }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 46, Bottom: 2); LayoutMode: Left; Background: (TexturePath: "../../Common/OptionBackgroundPatch.png", Border: 16);
                  Label { Anchor: (Left: 12); Style: LabelStyle(VerticalAlignment: Center, TextColor: #96a9be, FontSize: 14); Text: "Auto-Delete Days"; }
                  Group { FlexWeight: 1; }
                  $C.@TextField #RAutoDeleteDays { Anchor: (Width: 60, Height: 28, Right: 8); MaxLength: 4; }
                }
                Group { Anchor: (Height: 12); }
                Button #RSaveBtn {
                  Anchor: (Width: 160, Height: 34);
                  Style: ButtonStyle(Default: (Background: (Color: #44ff4420)), Hovered: (Background: (Color: #44ff4440)), Pressed: (Background: (Color: #44ff4460)));
                  Label { Style: LabelStyle(FontSize: 12, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Save Rent"; }
                }
              }

              // ========== ALL SHOPS PANEL ==========
              Group #SAPanelShops { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "All Shops"; }
                Group { Anchor: (Height: 6); }
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  $C.@TextField #SSearchField { Anchor: (Height: 28); FlexWeight: 1; MaxLength: 50; }
                  Group { Anchor: (Width: 6); }
                  Button #SSearchBtn {
                    Anchor: (Width: 60, Height: 28);
                    Style: ButtonStyle(Default: (Background: (Color: #00bcd420)), Hovered: (Background: (Color: #00bcd440)), Pressed: (Background: (Color: #00bcd460)));
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #00bcd4, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Search"; }
                  }
                }
                Group { Anchor: (Height: 6); }
                // Header
                Group { Anchor: (Left: 0, Right: 0, Height: 22); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label { Anchor: (Width: 160); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "NAME"; }
                  Label { Anchor: (Width: 100); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "OWNER"; }
                  Label { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "TYPE"; }
                  Label { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "ITEMS"; }
                  Label { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "STATUS"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff10); }
                // Rows 0-7
                Group #SRow0 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label #SName0 { Anchor: (Width: 160); Style: LabelStyle(FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Label #SOwner0 { Anchor: (Width: 100); Style: LabelStyle(FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
                  Label #SType0 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SItems0 { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SStatus0 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Group { FlexWeight: 1; }
                  Button #SDeleteBtn0 { Anchor: (Width: 50, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
                }
                Group #SRow1 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label #SName1 { Anchor: (Width: 160); Style: LabelStyle(FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Label #SOwner1 { Anchor: (Width: 100); Style: LabelStyle(FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
                  Label #SType1 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SItems1 { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SStatus1 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Group { FlexWeight: 1; }
                  Button #SDeleteBtn1 { Anchor: (Width: 50, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
                }
                Group #SRow2 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label #SName2 { Anchor: (Width: 160); Style: LabelStyle(FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Label #SOwner2 { Anchor: (Width: 100); Style: LabelStyle(FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
                  Label #SType2 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SItems2 { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SStatus2 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Group { FlexWeight: 1; }
                  Button #SDeleteBtn2 { Anchor: (Width: 50, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
                }
                Group #SRow3 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label #SName3 { Anchor: (Width: 160); Style: LabelStyle(FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Label #SOwner3 { Anchor: (Width: 100); Style: LabelStyle(FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
                  Label #SType3 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SItems3 { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SStatus3 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Group { FlexWeight: 1; }
                  Button #SDeleteBtn3 { Anchor: (Width: 50, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "DEL"; } }
                }
                Group #SRow4 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label #SName4 { Anchor: (Width: 160); Style: LabelStyle(FontSize: 11, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; }
                  Label #SOwner4 { Anchor: (Width: 100); Style: LabelStyle(FontSize: 11, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; }
                  Label #SType4 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SItems4 { Anchor: (Width: 50); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
                  Label #SStatus4 { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; }
