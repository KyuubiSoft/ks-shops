              Group { Anchor: (Width: 8); }
              Button #BNextBtn { Anchor: (Width: 60, Height: 28); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); Label { Style: (FontSize: 11, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "NEXT >"; } }
