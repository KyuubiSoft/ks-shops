            Group #TRow4 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime4 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer4 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller4 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem4 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty4 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice4 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax4 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow5 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime5 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer5 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller5 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem5 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty5 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice5 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax5 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow6 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime6 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer6 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller6 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem6 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty6 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice6 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax6 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow7 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime7 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer7 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller7 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem7 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty7 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice7 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax7 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow8 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime8 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer8 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller8 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem8 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty8 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice8 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax8 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow9 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime9 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer9 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller9 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem9 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty9 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice9 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax9 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }

            Label #TEmpty { Visible: false; Style: (FontSize: 12, TextColor: #667788, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "No transactions found."; Anchor: (Height: 40); }

            // Pagination
            Group {
              Anchor: (Left: 0, Right: 0, Height: 36, Top: 8);
              LayoutMode: Left;
              Group { FlexWeight: 1; }
              Button #TPrevBtn { Anchor: (Width: 60, Height: 28); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); Label { Style: (FontSize: 11, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "< PREV"; } }
              Group { Anchor: (Width: 8); }
