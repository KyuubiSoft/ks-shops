          // ==================== PANEL: STATISTICS ====================
          Group #SAPanelStats {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #00bfff, RenderBold: true, RenderUppercase: true); Text: "SERVER STATISTICS"; Anchor: (Height: 24); }

            // Shop counts
            Label { Style: (FontSize: 10, TextColor: #667788, RenderBold: true, RenderUppercase: true); Text: "SHOPS"; Anchor: (Height: 20); Padding: (Top: 8); }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Total Shops"; } Group { FlexWeight: 1; } Label #StatTotalShops { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Player Shops"; } Group { FlexWeight: 1; } Label #StatPlayerShops { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Admin Shops"; } Group { FlexWeight: 1; } Label #StatAdminShops { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Active (Open)"; } Group { FlexWeight: 1; } Label #StatActiveShops { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #44ff44, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Closed"; } Group { FlexWeight: 1; } Label #StatClosedShops { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #ff4444, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }

            // Economy
            Group { Anchor: (Left: 0, Right: 0, Height: 1, Bottom: 8, Top: 8); Background: (Color: #ffffff15); }
            Label { Style: (FontSize: 10, TextColor: #667788, RenderBold: true, RenderUppercase: true); Text: "ECONOMY"; Anchor: (Height: 20); }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Total Transaction Volume"; } Group { FlexWeight: 1; } Label #StatTotalVolume { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #ffd700, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Tax Collected"; } Group { FlexWeight: 1; } Label #StatTaxCollected { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #ff9944, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Rent Collected"; } Group { FlexWeight: 1; } Label #StatRentCollected { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #ff9944, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }

            // Top performers
            Group { Anchor: (Left: 0, Right: 0, Height: 1, Bottom: 8, Top: 8); Background: (Color: #ffffff15); }
            Label { Style: (FontSize: 10, TextColor: #667788, RenderBold: true, RenderUppercase: true); Text: "TOP PERFORMERS"; Anchor: (Height: 20); }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Top Seller"; } Group { FlexWeight: 1; } Label #StatTopSeller { Anchor: (Width: 200, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "-"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Most Sold Item"; } Group { FlexWeight: 1; } Label #StatTopItem { Anchor: (Width: 200, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "-"; } }
            Group { Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 4); LayoutMode: Left; Background: (Color: #ffffff06); Label { Anchor: (Left: 12, Width: 200); Style: (VerticalAlignment: Center, TextColor: #96a9be, FontSize: 13); Text: "Transactions Today"; } Group { FlexWeight: 1; } Label #StatTransactionsToday { Anchor: (Width: 120, Right: 12); Style: (FontSize: 13, TextColor: #bfcdd5, VerticalAlignment: Center, HorizontalAlignment: Right); Text: "0"; } }
          }

          // ==================== PANEL: BLACKLIST ====================
          Group #SAPanelBlacklist {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #00bfff, RenderBold: true, RenderUppercase: true); Text: "ITEM BLACKLIST"; Anchor: (Height: 24); }

            // Add bar
            Group {
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 10);
              LayoutMode: Left;
              $C.@TextField #BItemField { FlexWeight: 1; Anchor: (Height: 28); PlaceholderText: "Item ID to blacklist..."; }
              Group { Anchor: (Width: 8); }
              Button #BAddBtn {
                Anchor: (Width: 60, Height: 28);
                LayoutMode: CenterMiddle;
                Style: ButtonStyle(Default: (Background: (Color: #44ff4425)), Hovered: (Background: (Color: #44ff4445)), Pressed: (Background: (Color: #44ff4465)));
                Label { Style: (FontSize: 11, RenderBold: true, TextColor: #44ff44, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "ADD"; }
              }
            }

            // Blacklist rows 0-9
            Group #BRow0 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32, Bottom: 2); LayoutMode: Left; Background: (Color: #ffffff06); Label #BItemId0 { FlexWeight: 1; Style: (FontSize: 12, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; Padding: (Left: 10); } Button #BRemoveBtn0 { Anchor: (Width: 32, Height: 24); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); Label { Style: (FontSize: 11, RenderBold: true, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "X"; } } }
