              Button #PPrevBtn { Anchor: (Width: 60, Height: 28); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); Label { Style: (FontSize: 11, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "< PREV"; } }
              Group { Anchor: (Width: 8); }
              Label #PPageInfo { Anchor: (Width: 80); Style: (FontSize: 11, TextColor: #778899, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "1 / 1"; }
              Group { Anchor: (Width: 8); }
              Button #PNextBtn { Anchor: (Width: 60, Height: 28); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); Label { Style: (FontSize: 11, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "NEXT >"; } }
              Group { FlexWeight: 1; }
            }
          }

          // ==================== PANEL: TRANSACTIONS ====================
          Group #SAPanelTransactions {
            Visible: false;
            Anchor: (Left: 0, Right: 0, Top: 24, Bottom: 0);
            LayoutMode: TopScrolling;
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
            Padding: (Left: 16, Right: 16, Top: 12, Bottom: 16);

            Label { Style: (FontSize: 11, TextColor: #44ff44, RenderBold: true, RenderUppercase: true); Text: "TRANSACTION LOG"; Anchor: (Height: 24); }

            // Search + filter
            Group {
              Anchor: (Left: 0, Right: 0, Height: 36, Bottom: 10);
              LayoutMode: Left;
              $C.@TextField #TSearchField { FlexWeight: 1; Anchor: (Height: 28); PlaceholderText: "Search by player name..."; }
              Group { Anchor: (Width: 8); }
              Button #TSearchBtn {
                Anchor: (Width: 80, Height: 28);
                LayoutMode: CenterMiddle;
                Style: ButtonStyle(Default: (Background: (Color: #00bfff25)), Hovered: (Background: (Color: #00bfff45)), Pressed: (Background: (Color: #00bfff65)));
                Label { Style: (FontSize: 11, RenderBold: true, TextColor: #00bfff, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "SEARCH"; }
              }
            }

            // Column headers
            Group {
              Anchor: (Left: 0, Right: 0, Height: 24, Bottom: 4);
              LayoutMode: Left;
              Label { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "TIME"; Padding: (Left: 4); }
              Label { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "BUYER"; }
              Label { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "SELLER"; }
              Label { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "ITEM"; }
              Label { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "QTY"; }
              Label { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "PRICE"; }
              Label { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "TAX"; }
            }

            // Transaction rows 0-9
            Group #TRow0 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime0 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer0 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller0 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem0 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty0 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice0 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax0 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
            Group #TRow1 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 30, Bottom: 1); LayoutMode: Left; Background: (Color: #ffffff06); Label #TTime1 { Anchor: (Width: 80); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; Padding: (Left: 4); } Label #TBuyer1 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TSeller1 { Anchor: (Width: 90); Style: (FontSize: 10, TextColor: #8899aa, VerticalAlignment: Center); Text: ""; } Label #TItem1 { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; } Label #TQty1 { Anchor: (Width: 40); Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; } Label #TPrice1 { Anchor: (Width: 70); Style: (FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } Label #TTax1 { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #ff9944, VerticalAlignment: Center); Text: ""; } }
