$C = "../../Common.ui";

$C.@PageOverlay {
  Group {
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #SAPanel {
      @ContentPadding = Padding(Left: 0, Right: 0, Top: 0, Bottom: 0);
      Anchor: (Width: 960, Height: 700);

      #Title {
        Group {
          Anchor: (Height: 42);
          LayoutMode: Left;
          Padding: (Left: 16, Right: 8);
          Group { Anchor: (Width: 8); }
          Label #SATitleLbl {
            FlexWeight: 1;
            Style: (FontSize: 18, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
            Text: "SHOP ADMINISTRATION";
          }
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 17);

        Label #SAStatusMsg {
          Anchor: (Height: 24);
          Style: (FontSize: 12, TextColor: #888888, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Admin panel loading...";
        }
      }
    }
  }
}
