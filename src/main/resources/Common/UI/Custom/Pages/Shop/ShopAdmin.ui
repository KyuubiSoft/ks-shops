                  Button #BRemoveBtn3 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow4 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId4 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn4 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow5 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId5 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn5 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow6 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId6 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn6 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow7 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId7 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn7 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow8 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId8 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn8 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Group #BRow9 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left; Padding: (Left: 8, Right: 4);
                  Label #BItemId9 { FlexWeight: 1; Style: LabelStyle(FontSize: 11, TextColor: #cccccc, VerticalAlignment: Center); Text: ""; }
                  Button #BRemoveBtn9 { Anchor: (Width: 50, Height: 22); Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 9, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Remove"; } }
                }
                Label #BEmpty { Anchor: (Height: 30); Style: LabelStyle(FontSize: 11, TextColor: #556677, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "No blacklisted items."; }
                Group { Anchor: (Height: 4); }
                Group { Anchor: (Left: 0, Right: 0, Height: 28); LayoutMode: Left;
                  Button #BPrevBtn { Anchor: (Width: 30, Height: 24); Style: $C.@SecondaryButtonStyle; LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 12, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "<"; } }
                  Group { FlexWeight: 1; }
                  Label #BPageInfo { Style: LabelStyle(FontSize: 10, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "1/1"; }
                  Group { FlexWeight: 1; }
                  Button #BNextBtn { Anchor: (Width: 30, Height: 24); Style: $C.@SecondaryButtonStyle; LayoutMode: CenterMiddle;
                    Label { Style: LabelStyle(FontSize: 12, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ">"; } }
                }
              }

            }
          }
        }
      }
    }
  }
