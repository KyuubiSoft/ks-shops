            Group #BRow2 { Visible: false; Anchor: (Left: 0, Right: 0, Height: 32, Bottom: 2); LayoutMode: Left; Background: (Color: #ffffff06); Label #BItemId2 { FlexWeight: 1; Style: (FontSize: 12, TextColor: #bfcdd5, VerticalAlignment: Center); Text: ""; Padding: (Left: 10); } Button #BRemoveBtn2 { Anchor: (Width: 32, Height: 24); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ff444420)), Hovered: (Background: (Color: #ff444440)), Pressed: (Background: (Color: #ff444460))); Label { Style: (FontSize: 11, RenderBold: true, TextColor: #ff4444, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "X"; } } }
