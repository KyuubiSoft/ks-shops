              Anchor: (Left: 0, Right: 0, Height: 36, Top: 8);
              LayoutMode: Left;
              Group { FlexWeight: 1; }
              Button #BPrevBtn { Anchor: (Width: 60, Height: 28); LayoutMode: CenterMiddle; Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); Label { Style: (FontSize: 11, TextColor: #8899aa, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "< PREV"; } }
