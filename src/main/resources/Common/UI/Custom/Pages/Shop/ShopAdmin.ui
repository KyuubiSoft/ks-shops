              Label { Anchor: (Width: 120); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "OWNER"; }
              Label { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "STATUS"; }
              Label { Anchor: (Width: 60); Style: (FontSize: 10, TextColor: #667788, RenderBold: true, VerticalAlignment: Center); Text: "RATING"; }
