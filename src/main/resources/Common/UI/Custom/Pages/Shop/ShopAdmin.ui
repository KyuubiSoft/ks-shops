              // ========== RENTALS PANEL ==========
              Group #SAPanelRentals { Anchor: (Left: 0, Right: 0); LayoutMode: Top; Visible: false;
                Label { Style: LabelStyle(FontSize: 16, TextColor: #eeddcc, RenderBold: true); Text: "Rental Slots"; }
                Group { Anchor: (Height: 6); }

                // --- Search row ---
                Group { Anchor: (Left: 0, Right: 0, Height: 32); LayoutMode: Left;
                  $C.@TextField #RentSearchField { Anchor: (Height: 28); FlexWeight: 1; MaxLength: 50; }
                  Group { Anchor: (Width: 6); }
                  Button #RentSearchBtn {
                    Anchor: (Width: 60, Height: 28);
                    Style: ButtonStyle(Default: (Background: (Color: #00bcd420)), Hovered: (Background: (Color: #00bcd440)), Pressed: (Background: (Color: #00bcd460)));
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #00bcd4, HorizontalAlignment: Center, VerticalAlignment: Center); Text: "Search"; }
                  }
                }
                Group { Anchor: (Height: 6); }

                // --- Filter pills ---
                Group { Anchor: (Left: 0, Right: 0, Height: 26); LayoutMode: Left;
                  Button #RentFilterAll { Anchor: (Width: 70, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); LayoutMode: Left;
                    Group #RentFilterAllInd { Anchor: (Width: 3, Top: 4, Bottom: 4); Background: (Color: #00bfff); }
                    Group { Anchor: (Width: 4); }
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #bfcdd5, VerticalAlignment: Center); FlexWeight: 1; Text: "ALL"; }
                  }
                  Group { Anchor: (Width: 4); }
                  Button #RentFilterVacant { Anchor: (Width: 80, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); LayoutMode: Left;
                    Group #RentFilterVacantInd { Anchor: (Width: 3, Top: 4, Bottom: 4); Background: (Color: #00000000); }
                    Group { Anchor: (Width: 4); }
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #66bb6a, VerticalAlignment: Center); FlexWeight: 1; Text: "VACANT"; }
                  }
                  Group { Anchor: (Width: 4); }
                  Button #RentFilterAuction { Anchor: (Width: 80, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); LayoutMode: Left;
                    Group #RentFilterAuctionInd { Anchor: (Width: 3, Top: 4, Bottom: 4); Background: (Color: #00000000); }
                    Group { Anchor: (Width: 4); }
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #ffd700, VerticalAlignment: Center); FlexWeight: 1; Text: "AUCTION"; }
                  }
                  Group { Anchor: (Width: 4); }
                  Button #RentFilterRented { Anchor: (Width: 80, Height: 24); Style: ButtonStyle(Default: (Background: (Color: #ffffff10)), Hovered: (Background: (Color: #ffffff20)), Pressed: (Background: (Color: #ffffff30))); LayoutMode: Left;
                    Group #RentFilterRentedInd { Anchor: (Width: 3, Top: 4, Bottom: 4); Background: (Color: #00000000); }
                    Group { Anchor: (Width: 4); }
                    Label { Style: LabelStyle(FontSize: 10, TextColor: #00bcd4, VerticalAlignment: Center); FlexWeight: 1; Text: "RENTED"; }
                  }
                }
                Group { Anchor: (Height: 6); }

                // --- Column header ---
                Group { Anchor: (Left: 0, Right: 0, Height: 22); LayoutMode: Left; Padding: (Left: 8, Right: 8);
                  Label { Anchor: (Width: 130); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "SLOT"; }
                  Label { Anchor: (Width: 60); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "MODE"; }
                  Label { Anchor: (Width: 70); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "STATE"; }
                  Label { Anchor: (Width: 80); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "PRICE"; }
                  Label { FlexWeight: 1; Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "RENTER / ENDS"; }
                  Label { Anchor: (Width: 90); Style: LabelStyle(FontSize: 10, TextColor: #556677, VerticalAlignment: Center); Text: "ACTIONS"; }
                }
                Group { Anchor: (Left: 0, Right: 0, Height: 1); Background: (Color: #ffffff10); }

                // --- Rows 0-7 ---
