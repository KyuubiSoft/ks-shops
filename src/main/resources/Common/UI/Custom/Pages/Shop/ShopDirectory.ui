// ShopDirectory UI -- Main hub page for browsing ALL shops (960x650)
// NOTE: Cards are inlined (NOT macros) with unique per-card IDs. Macro-
// instanced child ItemIcons do not receive dynamic ItemId updates from Java
// even with 2-level selectors - the bank/pets pattern (unique IDs + flat
// selectors) is the known-working approach.
$C = "../../Common.ui";

// ===== ItemGrid Style for the item-search grid (mirrors ShopBrowse) =====
// Bigger slots (72 instead of 48) so the items tab matches the browse
// page's slot size and the directory feels less sparse.
@SearchSlotStyle = ItemGridStyle(
    SlotSpacing: 6,
    SlotSize: 72,
    SlotIconSize: 60,
    SlotBackground: "../../Pages/Bank/BankSlot.png"
);

// ===== Card button style (dark card hover) =====
@DirCardBtnStyle = ButtonStyle(
  Default: (Background: (Color: #1c2835)),
  Hovered: (Background: (Color: #2a3a4a)),
  Pressed: (Background: (Color: #1a2a38)),
  Disabled: (Background: (Color: #141a22)),
);

// ===== Tab button styles =====
@TabBtnActiveStyle = ButtonStyle(
  Default: (Background: (Color: #1a3050)),
  Hovered: (Background: (Color: #1e3858)),
  Pressed: (Background: (Color: #163050)),
);

@TabBtnInactiveStyle = ButtonStyle(
  Default: (Background: (Color: #141e28)),
  Hovered: (Background: (Color: #1c2835)),
  Pressed: (Background: (Color: #141a22)),
);

// ===== Page Layout =====

$C.@PageOverlay {
  Group #DirLayout {
    LayoutMode: CenterMiddle;

    $C.@DecoratedContainer #MainContent {
      Anchor: (Width: 960, Height: 650);

      // ==================== TITLE BAR ====================
      #Title {
        Group {
          LayoutMode: Left;
          Anchor: (Height: 42);
          Padding: (Left: 16, Right: 16);

          Group { FlexWeight: 1; }

          Label #DirTitle {
            Style: (FontSize: 18, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
            Text: "SHOP DIRECTORY";
            Padding: (Top: 6);
          }

          Group { FlexWeight: 1; }
        }
      }

      // ==================== CONTENT ====================
      #Content {
        LayoutMode: Top;

        // ---- Mode Bar (SHOPS vs ITEMS search) ----
        Group #ModeBar {
          Anchor: (Height: 32);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12, Top: 4, Bottom: 4);

          Button #ModeShops {
            FlexWeight: 1;
            Anchor: (Height: 24);
            Style: @TabBtnActiveStyle;
            LayoutMode: Top;
            Label #ModeShopsLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #bfcdd5, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "SHOPS";
              FlexWeight: 1;
            }
            Group #ModeShopsInd { Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }

          Group { Anchor: (Width: 6); }

          Button #ModeItems {
            FlexWeight: 1;
            Anchor: (Height: 24);
            Style: @TabBtnInactiveStyle;
            LayoutMode: Top;
            Label #ModeItemsLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #778899, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "ITEMS";
              FlexWeight: 1;
            }
            Group #ModeItemsInd { Visible: false; Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }
        }

        // ---- Tab Bar ----
        Group #TabBar {
          Anchor: (Height: 36);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12, Top: 4, Bottom: 4);

          Button #TabAll {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: @TabBtnActiveStyle;
            LayoutMode: Top;
            Label #TabAllLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #bfcdd5, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "ALL SHOPS";
              FlexWeight: 1;
            }
            Group #TabAllInd { Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }

          Group { Anchor: (Width: 4); }

          Button #TabAdmin {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: @TabBtnInactiveStyle;
            LayoutMode: Top;
            Label #TabAdminLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #778899, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "ADMIN";
              FlexWeight: 1;
            }
            Group #TabAdminInd { Visible: false; Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }

          Group { Anchor: (Width: 4); }

          Button #TabPlayer {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: @TabBtnInactiveStyle;
            LayoutMode: Top;
            Label #TabPlayerLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #778899, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "PLAYER";
              FlexWeight: 1;
            }
            Group #TabPlayerInd { Visible: false; Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }

          Group { Anchor: (Width: 4); }

          Button #TabFeatured {
            FlexWeight: 1;
            Anchor: (Height: 28);
            Style: @TabBtnInactiveStyle;
            LayoutMode: Top;
            Label #TabFeaturedLabel {
              Style: (FontSize: 11, RenderBold: true, TextColor: #778899, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
              Text: "FEATURED";
              FlexWeight: 1;
            }
            Group #TabFeaturedInd { Visible: false; Anchor: (Left: 0, Right: 0, Height: 2); Background: (Color: #00bcd4); }
          }

          Group { Anchor: (Width: 12); }

          $C.@DropdownBox #SortDropdown {
            Anchor: (Width: 160, Height: $C.@DropdownBoxHeight);

            DropdownEntry { Value: "rating"; Text: "Top Rated"; }
            DropdownEntry { Value: "newest"; Text: "Newest"; }
            DropdownEntry { Value: "name"; Text: "Name A-Z"; }
            DropdownEntry { Value: "most_sales"; Text: "Most Sales"; }
            DropdownEntry { Value: "price_low"; Text: "Price: Low"; }
            DropdownEntry { Value: "price_high"; Text: "Price: High"; }
          }
        }

        // ---- Filter Bar ----
        Group #FilterBar {
          Anchor: (Height: 34);
          LayoutMode: Left;
          Padding: (Left: 12, Right: 12, Top: 2, Bottom: 4);

          $C.@TextField #SearchField {
            @PlaceholderText = "Search items or shops...";
            FlexWeight: 1;
            Anchor: (Height: 28);
            MaxLength: 64;
          }

          Group { Anchor: (Width: 8); }

          $C.@DropdownBox #CategoryFilter {
            Anchor: (Width: 140, Height: $C.@DropdownBoxHeight);

            DropdownEntry { Value: ""; Text: "All Categories"; }
            DropdownEntry { Value: "weapons"; Text: "Weapons"; }
            DropdownEntry { Value: "armor"; Text: "Armor"; }
            DropdownEntry { Value: "tools"; Text: "Tools"; }
            DropdownEntry { Value: "resources"; Text: "Resources"; }
            DropdownEntry { Value: "potions"; Text: "Potions"; }
            DropdownEntry { Value: "food"; Text: "Food"; }
            DropdownEntry { Value: "building"; Text: "Building"; }
            DropdownEntry { Value: "misc"; Text: "Misc"; }
          }

          Group { Anchor: (Width: 8); }

          $C.@DropdownBox #RatingFilter {
            Anchor: (Width: 100, Height: $C.@DropdownBoxHeight);

            DropdownEntry { Value: "0"; Text: "Any Rating"; }
            DropdownEntry { Value: "1"; Text: "1+ Stars"; }
            DropdownEntry { Value: "2"; Text: "2+ Stars"; }
            DropdownEntry { Value: "3"; Text: "3+ Stars"; }
            DropdownEntry { Value: "4"; Text: "4+ Stars"; }
          }
        }

        // ---- Card Grid (both shops-mode and items-mode grids live here) ----
        Group #GridContainer {
          FlexWeight: 1;
          LayoutMode: TopScrolling;
          ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Padding: (Left: 10, Right: 10, Top: 4);

          // ============ Shop Cards (8, inline with unique IDs) ============
          Group #ShopGrid {
            LayoutMode: LeftCenterWrap;

            Group #DCard0 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn0 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 52); LayoutMode: Left;
                    Group { Anchor: (Width: 48, Height: 48); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
                      ItemIcon #DAvatar0 { Anchor: (Width: 44, Height: 44); ItemId: "Ingredient_Bar_Gold"; } }
                    Group { Anchor: (Width: 6); }
                    Group { FlexWeight: 1; LayoutMode: Top;
                      Label #DName0 { Anchor: (Height: 20); Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, VerticalAlignment: Center); Text: ""; }
                      Label #DOwner0 { Anchor: (Height: 16); Style: (FontSize: 10, TextColor: #96a9be, VerticalAlignment: Center); Text: ""; }
                      Label #DStatusOpen0 { Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #4caf50, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusClosed0 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #cc4444, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusFeatured0 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } }
                  Group { Anchor: (Height: 5); LayoutMode: CenterMiddle; Group { Anchor: (Width: 190, Height: 1); Background: (Color: #252f3a); } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2);
                    Label #DRating0 { Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2, Right: 2);
                    Label #DItems0 { Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; FlexWeight: 1; }
                    Label #DDistance0 { Style: (FontSize: 10, TextColor: #7caacc, VerticalAlignment: Center, HorizontalAlignment: End); Text: ""; } }
                  Group { Anchor: (Height: 18); LayoutMode: Left; Padding: (Left: 2);
                    Label #DCategory0 { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } } } }

            Group #DCard1 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn1 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 52); LayoutMode: Left;
                    Group { Anchor: (Width: 48, Height: 48); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
