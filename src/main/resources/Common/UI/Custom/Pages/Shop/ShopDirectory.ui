                  Group { Anchor: (Height: 18); LayoutMode: Left; Padding: (Left: 2);
                    Label #DCategory2 { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } } } }

            Group #DCard3 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn3 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 52); LayoutMode: Left;
                    Group { Anchor: (Width: 48, Height: 48); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
