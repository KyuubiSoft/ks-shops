            Group #DCard6 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn6 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
