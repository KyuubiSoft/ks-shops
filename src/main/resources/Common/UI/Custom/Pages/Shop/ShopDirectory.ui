                      Label #DStatusOpen3 { Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #4caf50, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusClosed3 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #cc4444, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusFeatured3 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } }
                  Group { Anchor: (Height: 5); LayoutMode: CenterMiddle; Group { Anchor: (Width: 190, Height: 1); Background: (Color: #252f3a); } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2);
                    Label #DRating3 { Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2, Right: 2);
                    Label #DItems3 { Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; FlexWeight: 1; }
                    Label #DDistance3 { Style: (FontSize: 10, TextColor: #7caacc, VerticalAlignment: Center, HorizontalAlignment: End); Text: ""; } }
                  Group { Anchor: (Height: 18); LayoutMode: Left; Padding: (Left: 2);
                    Label #DCategory3 { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } } } }

            Group #DCard4 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn4 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 52); LayoutMode: Left;
                    Group { Anchor: (Width: 48, Height: 48); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
                      ItemIcon #DAvatar4 { Anchor: (Width: 44, Height: 44); ItemId: "Ingredient_Bar_Gold"; } }
                    Group { Anchor: (Width: 6); }
                    Group { FlexWeight: 1; LayoutMode: Top;
                      Label #DName4 { Anchor: (Height: 20); Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, VerticalAlignment: Center); Text: ""; }
                      Label #DOwner4 { Anchor: (Height: 16); Style: (FontSize: 10, TextColor: #96a9be, VerticalAlignment: Center); Text: ""; }
                      Label #DStatusOpen4 { Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #4caf50, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusClosed4 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #cc4444, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusFeatured4 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } }
