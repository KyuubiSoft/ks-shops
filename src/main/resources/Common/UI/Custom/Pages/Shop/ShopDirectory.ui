                  Group { Anchor: (Height: 5); LayoutMode: CenterMiddle; Group { Anchor: (Width: 190, Height: 1); Background: (Color: #252f3a); } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2);
                    Label #DRating6 { Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2, Right: 2);
                    Label #DItems6 { Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; FlexWeight: 1; }
                    Label #DDistance6 { Style: (FontSize: 10, TextColor: #7caacc, VerticalAlignment: Center, HorizontalAlignment: End); Text: ""; } }
                  Group { Anchor: (Height: 18); LayoutMode: Left; Padding: (Left: 2);
                    Label #DCategory6 { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } } } }

            Group #DCard7 { Visible: false; Anchor: (Width: 220, Height: 155); Padding: (Full: 3);
              Button #DBtn7 { Anchor: (Full: 0); LayoutMode: Full; Padding: (Full: 2); Style: @DirCardBtnStyle; TooltipText: "";
                Group { Anchor: (Full: 0); LayoutMode: Top; Padding: (Full: 4);
                  Group { Anchor: (Height: 52); LayoutMode: Left;
                    Group { Anchor: (Width: 48, Height: 48); Background: (Color: #1a2530); Padding: (Full: 2); LayoutMode: CenterMiddle;
                      ItemIcon #DAvatar7 { Anchor: (Width: 44, Height: 44); ItemId: "Ingredient_Bar_Gold"; } }
                    Group { Anchor: (Width: 6); }
                    Group { FlexWeight: 1; LayoutMode: Top;
                      Label #DName7 { Anchor: (Height: 20); Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, VerticalAlignment: Center); Text: ""; }
                      Label #DOwner7 { Anchor: (Height: 16); Style: (FontSize: 10, TextColor: #96a9be, VerticalAlignment: Center); Text: ""; }
                      Label #DStatusOpen7 { Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #4caf50, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusClosed7 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #cc4444, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusFeatured7 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } }
                  Group { Anchor: (Height: 5); LayoutMode: CenterMiddle; Group { Anchor: (Width: 190, Height: 1); Background: (Color: #252f3a); } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2);
                    Label #DRating7 { Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2, Right: 2);
                    Label #DItems7 { Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; FlexWeight: 1; }
                    Label #DDistance7 { Style: (FontSize: 10, TextColor: #7caacc, VerticalAlignment: Center, HorizontalAlignment: End); Text: ""; } }
                  Group { Anchor: (Height: 18); LayoutMode: Left; Padding: (Left: 2);
                    Label #DCategory7 { Style: (FontSize: 9, TextColor: #5a6a7a, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } } } }
          }

          // ============ Item Search Grid (native 9x5 ItemGrid = 45 slots) ============
          Group #ItemGrid {
            Visible: false;
            LayoutMode: CenterMiddle;
            Padding: (Top: 6);

            ItemGrid #ItemSearchGrid {
              Anchor: (Width: 700, Height: 395);
              SlotsPerRow: 9;
              Style: @SearchSlotStyle;
              Background: #1a2332(0);
              Padding: 0;
            }
          }
        }

        // ---- Footer: Pagination ----
        Group #Footer {
          Anchor: (Height: 34);
          LayoutMode: Top;
          Padding: (Horizontal: 10);

          Group { Anchor: (Height: 1); Background: (Color: #19252f); }

          Group {
            FlexWeight: 1;
            LayoutMode: Left;
            Padding: (Left: 10, Right: 10);

            $C.@SmallSecondaryTextButton #DPrevBtn {
              @Anchor = (Width: 50);
              @Text = "<";
              Visible: false;
            }

            Group { FlexWeight: 1; }

            Label #DPageInfo {
              Anchor: (Width: 80);
              Style: (FontSize: 11, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "Page 1/1";
            }

            Group { Anchor: (Width: 8); }

            Label #DResultCount {
              Anchor: (Width: 80);
              Style: (FontSize: 10, TextColor: #5a6a7a, HorizontalAlignment: Center, VerticalAlignment: Center);
              Text: "";
            }

            Group { FlexWeight: 1; }

            $C.@SmallSecondaryTextButton #DNextBtn {
              @Anchor = (Width: 50);
              @Text = ">";
              Visible: false;
            }
          }
        }
      }
    }
  }

  // ==================== BUY CONFIRM OVERLAY ====================
  // In-place fast-buy dialog for the items-search mode. Clicking a slot in
  // #ItemSearchGrid shows this overlay; the user can hit BUY (instant purchase),
  // VISIT SHOP (navigate to ShopBrowsePage), or CANCEL.
  Group #DirConfirmOverlay {
    Visible: false;
    Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
    LayoutMode: CenterMiddle;
    Background: (Color: #000000aa);

    $C.@Container #DirConfirmDialog {
      Anchor: (Width: 400, Height: 380);

      #Title {
        Label #DirConfirmTitle {
          Style: (FontSize: 16, RenderBold: true, TextColor: #ffd700, HorizontalAlignment: Center, VerticalAlignment: Center, RenderUppercase: true);
          Padding: (Horizontal: 19);
          Text: "BUY ITEM";
        }
      }

      #Content {
        LayoutMode: Top;
        Padding: (Full: 14);

        // ---- Item row: icon + item name + shop name ----
        Group {
          LayoutMode: Left;
          Anchor: (Height: 60);

          Group #DirConfirmIconBg {
            Anchor: (Width: 54, Height: 54);
            Background: (Color: #1a2530);
            Padding: (Full: 3);
            LayoutMode: CenterMiddle;
            ItemIcon #DirConfirmIcon { Anchor: (Width: 48, Height: 48); ItemId: "Ingredient_Bar_Gold"; }
          }

          Group { Anchor: (Width: 12); }

          Group {
            FlexWeight: 1;
            LayoutMode: Top;
            Label #DirConfirmItemName {
              Anchor: (Height: 22);
              Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
            Label #DirConfirmShop {
              Anchor: (Height: 18);
              Style: (FontSize: 12, TextColor: #4fc3f7, RenderBold: true, VerticalAlignment: Center);
              Text: "";
            }
            // Two pre-coloured owner labels (player = lavender, admin =
            // magenta). Visibility is toggled from Java at build time
            // because Style.TextColor is not dynamically settable.
            Label #DirConfirmOwnerPlayer {
              Anchor: (Height: 16);
              Style: (FontSize: 10, TextColor: #9fa8da, VerticalAlignment: Center);
              Text: "";
            }
            Label #DirConfirmOwnerAdmin {
              Anchor: (Height: 16);
              Style: (FontSize: 10, TextColor: #ce93d8, RenderBold: true, VerticalAlignment: Center);
              Text: "";
              Visible: false;
            }
          }
        }

        Group { Anchor: (Height: 10); }

        // ---- Info rows: price per unit, stock ----
        Group {
          Anchor: (Height: 1);
          Background: (Color: #252f3a);
        }

        Group { Anchor: (Height: 6); }

        // Price per unit (amber so it stands apart from the gold total at
        // the bottom of the dialog).
        Label #DirConfirmPrice {
          Anchor: (Height: 18);
          Style: (FontSize: 13, TextColor: #ffb74d, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
        }

        // Stock: four pre-coloured labels (green/amber/red/cyan). Only
        // the matching one is Visible; Java flips them in buildBuyConfirm
        // Overlay based on the remaining quantity.
        Label #DirConfirmStockGood {
          Anchor: (Height: 16);
          Style: (FontSize: 11, TextColor: #66bb6a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
        }
        Label #DirConfirmStockLow {
          Anchor: (Height: 16);
          Style: (FontSize: 11, TextColor: #ffb74d, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Visible: false;
        }
        Label #DirConfirmStockCrit {
          Anchor: (Height: 16);
          Style: (FontSize: 11, TextColor: #ff5252, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Visible: false;
        }
        Label #DirConfirmStockUnlim {
          Anchor: (Height: 16);
          Style: (FontSize: 11, TextColor: #26c6da, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
          Visible: false;
        }

        Group { Anchor: (Height: 8); }

        // ---- Quantity slider (SliderNumberField centered in the row; equal
        // side-label widths so the slider track is symmetrically middle) ----
        Group {
          LayoutMode: Left;
          Anchor: (Height: 34);
          Padding: (Left: 18, Right: 18, Top: 8);

          Label {
            Anchor: (Width: 50, Height: 18);
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
            Text: "Qty";
          }

          Group {
            FlexWeight: 1;
            LayoutMode: CenterMiddle;

            SliderNumberField #DirConfirmQtySlider {
              Anchor: (Width: 220, Height: 5);
              SliderStyle: $C.@DefaultSliderStyle;
              NumberFieldStyle: $C.@DefaultInputFieldStyle;
              Min: 1;
              Max: 64;
            }
          }

          Label #DirConfirmQty {
            Anchor: (Width: 50, Height: 18);
            Style: (FontSize: 18, RenderBold: true, TextColor: #ffffff, HorizontalAlignment: End, VerticalAlignment: Center);
            Text: "1";
          }
        }

        Group { Anchor: (Height: 4); }

        // ---- Total ----
        Label #DirConfirmTotal {
          Anchor: (Height: 22);
          Style: (FontSize: 14, TextColor: #ffd700, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "";
        }

        Group { FlexWeight: 1; }

        // ---- Button row: BUY / VISIT SHOP / CANCEL ----
        Group {
          LayoutMode: Left;
          Anchor: (Height: 38);
          Padding: (Left: 4, Right: 4);

          $C.@TextButton #DirConfirmBuy {
            @Anchor = (Width: 110);
            @Text = "BUY";
          }

          Group { FlexWeight: 1; }

          $C.@TextButton #DirConfirmVisit {
            @Anchor = (Width: 130);
            @Text = "VISIT SHOP";
          }

          Group { FlexWeight: 1; }

          $C.@CancelTextButton #DirConfirmCancel {
            @Anchor = (Width: 110);
            @Text = "CANCEL";
          }
        }
      }
    }
  }
}
