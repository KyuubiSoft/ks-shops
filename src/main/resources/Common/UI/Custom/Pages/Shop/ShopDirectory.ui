                    Group { Anchor: (Width: 6); }
                    Group { FlexWeight: 1; LayoutMode: Top;
                      Label #DName2 { Anchor: (Height: 20); Style: (FontSize: 13, TextColor: #bfcdd5, RenderBold: true, VerticalAlignment: Center); Text: ""; }
                      Label #DOwner2 { Anchor: (Height: 16); Style: (FontSize: 10, TextColor: #96a9be, VerticalAlignment: Center); Text: ""; }
                      Label #DStatusOpen2 { Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #4caf50, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusClosed2 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #cc4444, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; }
                      Label #DStatusFeatured2 { Visible: false; Anchor: (Height: 14); Style: (FontSize: 9, TextColor: #ffd700, RenderBold: true, VerticalAlignment: Center, RenderUppercase: true); Text: ""; } } }
                  Group { Anchor: (Height: 5); LayoutMode: CenterMiddle; Group { Anchor: (Width: 190, Height: 1); Background: (Color: #252f3a); } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2);
                    Label #DRating2 { Style: (FontSize: 12, TextColor: #ffd700, VerticalAlignment: Center); Text: ""; } }
                  Group { Anchor: (Height: 20); LayoutMode: Left; Padding: (Left: 2, Right: 2);
                    Label #DItems2 { Style: (FontSize: 10, TextColor: #778899, VerticalAlignment: Center); Text: ""; FlexWeight: 1; }
